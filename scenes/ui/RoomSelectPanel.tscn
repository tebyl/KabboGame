[node name="CreateForm" type="HBoxContainer" parent="Root/Card/Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="NameInput" type="LineEdit" parent="Root/Card/Margin/VBox/CreateForm"]
