[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/InventoryPanel.gd" id="1_inventory_script"]

[node name="InventoryPanel" type="CanvasLayer"]
script = ExtResource("1_inventory_script")

[node name="Root" type="Control" parent="."]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2

[node name="Panel" type="PanelContainer" parent="Root"]
layout_mode = 1
anchors_preset = 6
anchor_left = 1.0
anchor_top = 0.5
anchor_right = 1.0
anchor_bottom = 0.5
offset_left = -280.0
offset_top = -210.0
offset_right = -12.0
offset_bottom = 210.0
grow_horizontal = 0
grow_vertical = 2
mouse_filter = 0

[node name="Margin" type="MarginContainer" parent="Root/Panel"]
layout_mode = 2
theme_override_constants/margin_left = 10
theme_override_constants/margin_top = 10
theme_override_constants/margin_right = 10
theme_override_constants/margin_bottom = 10

[node name="VBox" type="VBoxContainer" parent="Root/Panel/Margin"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Header" type="HBoxContainer" parent="Root/Panel/Margin/VBox"]
layout_mode = 2

[node name="Title" type="Label" parent="Root/Panel/Margin/VBox/Header"]
layout_mode = 2
size_flags_horizontal = 3
text = "Inventario"

[node name="CloseButton" type="Button" parent="Root/Panel/Margin/VBox/Header"]
layout_mode = 2
text = "X"

[node name="Categories" type="VBoxContainer" parent="Root/Panel/Margin/VBox"]
layout_mode = 2

[node name="Separator" type="HSeparator" parent="Root/Panel/Margin/VBox"]
layout_mode = 2

[node name="Items" type="VBoxContainer" parent="Root/Panel/Margin/VBox"]
layout_mode = 2
size_flags_vertical = 3

[connection signal="pressed" from="Root/Panel/Margin/VBox/Header/CloseButton" to="." method="_on_close_pressed"]
