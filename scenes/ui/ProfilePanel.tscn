[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/ProfilePanel.gd" id="1_profile_script"]

[node name="ProfilePanel" type="CanvasLayer"]
script = ExtResource("1_profile_script")

[node name="Root" type="Control" parent="."]
visible = false
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 0

[node name="Overlay" type="ColorRect" parent="Root"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 0
color = Color(0, 0, 0, 0.45)

[node name="Card" type="PanelContainer" parent="Root"]
custom_minimum_size = Vector2(420, 320)
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -210.0
offset_top = -160.0
offset_right = 210.0
offset_bottom = 160.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 0

[node name="Margin" type="MarginContainer" parent="Root/Card"]
layout_mode = 2
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 16
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 16

[node name="VBox" type="VBoxContainer" parent="Root/Card/Margin"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Title" type="Label" parent="Root/Card/Margin/VBox"]
layout_mode = 2
text = "Perfil"
horizontal_alignment = 1

[node name="NameInput" type="LineEdit" parent="Root/Card/Margin/VBox"]
layout_mode = 2
max_length = 16
placeholder_text = "Nombre"

[node name="VariantLabel" type="Label" parent="Root/Card/Margin/VBox"]
layout_mode = 2
text = "Color de camisa"

[node name="ColorButtons" type="HBoxContainer" parent="Root/Card/Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="DefaultButton" type="Button" parent="Root/Card/Margin/VBox/ColorButtons"]
layout_mode = 2
